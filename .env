ASPNETCORE_ENVIRONMENT=Development

DICTIONARY_CONTAINER_NAME=dictionary
DICTIONARY_HOST_PORT=5280
DICTIONARY_CONTAINER_PORT=8080
DICTIONARY_DB=dictionary
DICTIONARY_USER=dictionary_user
DICTIONARY_PASSWORD=password
DICTIONARY_CONNECTION_STRING=Host=postgres;Port=5432;Database=dictionary;Username=dictionary_user;Password=password

AUTH_CONTAINER_NAME=auth
AUTH_HOST_PORT=5279
AUTH_CONTAINER_PORT=8080
AUTH_DB=auth
AUTH_USER=auth_user
AUTH_PASSWORD=password
AUTH_CONNECTION_STRING=Host=postgres;Port=5432;Database=auth;Username=auth_user;Password=password
AUTH_ISSUER=http://auth:8080
AUTH_AUDIENCE=Admission.Clients
AUTH_TOKEN_PEPPER=change-me-auth-token-pepper
AUTH_ADMIN_SEED_ENABLED=true
AUTH_ADMIN_SEED_EMAIL=admin@admission.local
AUTH_ADMIN_SEED_PASSWORD=Admin123!ChangeMe
AUTH_DEBUG_EXPOSE_ACTION_TOKENS=false

MAIL_MANAGER_CONTAINER_NAME=mail-manager
MAIL_MANAGER_HOST_PORT=5278
MAIL_MANAGER_CONTAINER_PORT=8080

RABBITMQ_HOST=rabbit-mq
RABBITMQ_CONTAINER_NAME=message-broker
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

MAILDEV_HOST=mail-dev
MAILDEV_CONTAINER_NAME=mail-dev
MAILDEV_SMTP_PORT=1025
MAILDEV_WEB_PORT=1080
SMTP_HOST_NAME=Admission
SMTP_HOST_EMAIL=admission@mail.loc
SMTP_POOL_SIZE=5

REDIS_CONTAINER_NAME=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis:6379
REDIS_INSTANCE_NAME=mail-cache

REDIS_INSIGHT_CONTAINER_NAME=redis-insight
REDIS_INSIGHT_PORT=5540

POSTGRES_CONTAINER_NAME=postgres
POSTGRES_IMAGE_TAG=18
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=postgres
MAIL_INBOX_DB=mail_inbox
MAIL_INBOX_USER=mail_inbox_user
MAIL_INBOX_PASSWORD=password
MAIL_INBOX_CONNECTION_STRING=Host=postgres;Port=5432;Database=mail_inbox;Username=mail_inbox_user;Password=password

MINIO_CONTAINER_NAME=s3
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
