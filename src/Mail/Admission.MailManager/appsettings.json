{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  
  "MessagingParams": {
    "Host": "localhost",
    "Port": "5672",
    "User": "admin",
    "Password": "admin"
  },

  "SmtpOptions": {
    "Host": "localhost",
    "Port": "1025",
    "HostName": "Admission",
    "HostEmail": "admission@mail.loc",
    "PoolSize": "5"
  },
  
  "Redis": {
    "ConnectionString": "localhost:6379",
